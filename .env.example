# Copy this file to .env and fill in your values
# Get a bot token: open Telegram, talk to @BotFather, /newbot
TELEGRAM_BOT_TOKEN=123456:your-token-here

# ---- Model profiles ----
# QUALITY profile (default; needs ~10GB RAM, e.g. a 16-32GB machine):
#   WHISPER_MODEL=large-v3-turbo
#   LLM_MODEL_PATH=models/Qwen2.5-7B-Instruct-Q4_K_M.gguf
# LITE profile (fits an 8GB VPS):
#   WHISPER_MODEL=small
#   LLM_MODEL_PATH=models/Qwen2.5-3B-Instruct-Q4_K_M.gguf
#WHISPER_MODEL=large-v3-turbo
#LLM_MODEL_PATH=models/Qwen2.5-7B-Instruct-Q4_K_M.gguf
